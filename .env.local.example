# Supabase — create a project at https://supabase.com, then copy from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — create at https://resend.com, verify your sending domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@whatchanged.example

# Admin export password (any strong string you choose)
ADMIN_PASSWORD=change-me-to-something-strong

# Public site URL — used to build unsubscribe links in newsletter emails
NEXT_PUBLIC_SITE_URL=https://whatchanged.co
